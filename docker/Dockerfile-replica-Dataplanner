# STAGE 1: Build Stage (Gradle)
# Build the DataPlanner jar inside Docker so the deployed artifact always
# matches current sources, and produce a single coherent runtime classpath
# via :DataPlanner:copyRuntimeLibs.
FROM gradle:8.5-jdk21 AS build-stage

WORKDIR /home/gradle/project
COPY --chown=gradle:gradle . .

RUN ./gradlew :DataPlanner:assemble :DataPlanner:copyRuntimeLibs --no-daemon

# STAGE 2: Final Runtime Image
FROM tomcat:9.0-jdk21

# Add 'contrib' and 'non-free' repos for specific Linux tools, then install
# everything we need in one apt invocation and clear the apt cache.
RUN sed -i 's/main/main contrib non-free/g' /etc/apt/sources.list && \
    apt-get update && \
    apt-get install -y vim postgresql-client zfsutils-linux ntpdate && \
    rm -rf /var/lib/apt/lists/*

# Set environment variables
ENV DATAPLANNER_HOME="/usr/local/bluestorm/frontend/dataplanner"
ENV DATAPLANNER_FILE="DataPlanner-0.0.4-SNAPSHOT.jar"
ENV DATAPLANNER_PATH="${DATAPLANNER_HOME}/bin/${DATAPLANNER_FILE}"
ENV dataplanner_out_log="/var/log/dataplanner-startup.log"

# Create necessary directories
RUN mkdir -p ${DATAPLANNER_HOME}/bin/lib /var/log /app /etc/spectralogic /etc/spectra && \
    chmod 777 /var/log

# --- COPY FROM BUILD STAGE ---
COPY --from=build-stage /home/gradle/project/DataPlanner/build/runtime-libs/ ${DATAPLANNER_HOME}/bin/lib/
COPY --from=build-stage /home/gradle/project/DataPlanner/build/libs/${DATAPLANNER_FILE} ${DATAPLANNER_HOME}/bin/

# --- COPY LOCAL CONFIGS ---
COPY docker/entrypoint-dataplanner.sh /app/entrypoint.sh
COPY docker/tapesystem-replica.properties /etc/spectralogic/tapesystem.properties
COPY DataPlanner/src/test/resources/etc/spectra/serial_number /etc/spectra/
COPY DataPlanner/src/test/resources/etc/spectra/pf-s3port.conf /etc/spectra/
COPY docker/simulator_data /etc/spectra/
COPY docker/version.dataplanner.conf /etc/version.conf
COPY DataPlanner/src/main/resources/log4j.xml /app/log4j.xml
COPY docker/entrypoint-time-sync.sh /usr/local/bin/entrypoint-time-sync.sh
RUN chmod +x /usr/local/bin/entrypoint-time-sync.sh

RUN chmod +x /app/entrypoint.sh ${DATAPLANNER_HOME}/bin/${DATAPLANNER_FILE}

# Set working directory
WORKDIR ${DATAPLANNER_HOME}/bin/

# Start dataplanner using the entrypoint script
ENTRYPOINT ["/usr/local/bin/entrypoint-time-sync.sh", "/app/entrypoint.sh"]
